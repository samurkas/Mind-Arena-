{
    "name": "mind-arena",
    "productName": "Mind Arena",
    "version": "2.0.0",
    "description": "Mind Arena - Bilgi Yarışması Oyunu",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "server": "node server.js",
        "build": "electron-builder --win --config.win.signAndEditExecutable=false"
    },
    "keywords": [
        "trivia",
        "game",
        "multiplayer",
        "socket.io",
        "samurkas"
    ],
    "author": "SAMURKAÅž",
    "license": "MIT",
    "dependencies": {
        "@capacitor/cli": "^8.1.0",
        "@capacitor/core": "^8.1.0",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "socket.io": "^4.6.1"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    },
    "build": {
        "appId": "com.mind.arena",
        "productName": "Mind Arena",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!dist/**",
            "!.vscode/**",
            "!*.md",
            "!.gitignore"
        ],
        "win": {
            "target": [
                {
                    "target": "portable",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "icon.png",
            "signAndEditExecutable": false
        },
        "portable": {
            "artifactName": "Mind-Arena.exe"
        }
    }
}
